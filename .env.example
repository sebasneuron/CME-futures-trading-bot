# Interactive Brokers
IB_HOST=127.0.0.1
IB_PORT=7497
IB_CLIENT_ID=7

# Trading mode
TRADING_ENABLED=0

# Instruments / sizing
FUT_SYMBOL=ES
FUT_EXCHANGE=CME
FUT_CURRENCY=USD
FUT_USE_FRONT_MONTH=1
FUT_FRONT_MONTH_OFFSET=0

SPY_SYMBOL=SPY
SPY_EXCHANGE=ARCA
SPY_CURRENCY=USD

# Approx conversion from SPY dollars to SPX index points
SPY_TO_INDEX_FACTOR=10.0

# Carry inputs (fallbacks)
RISK_FREE_RATE_ANNUAL=0.045
DIVIDEND_YIELD_ANNUAL=0.014

# Optional: fetch risk-free rate from FRED
FRED_API_KEY=
FRED_SERIES_ID=DTB3

# Trading thresholds
ENTRY_THRESHOLD_BPS=20
EXIT_THRESHOLD_BPS=5
ESTIMATED_COST_BPS=4
COOLDOWN_SECONDS=30
MAX_HOLD_DAYS=5

# Risk limits
MAX_FUT_CONTRACTS=1
DAILY_LOSS_LIMIT_USD=250.0
STOP_LOSS_BPS=40
HEDGE_TIMEOUT_SECONDS=5

# Logging / DB
LOG_LEVEL=INFO
DB_PATH=arb_bot.sqlite3

# Manual kill switch (set to 1 to disable trading)
KILL_SWITCH=0
